pipeline {

    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/Chandan6169/Flutter_FastAPI_Posgresql_Docker-main.git'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker compose build'
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker compose up -d'
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }
}



